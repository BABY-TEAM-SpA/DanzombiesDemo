  - profile: {fileID: -8844993947990760528, guid: 1979baf0d53bcc148ab8e133946026d7, type: 3}
    Character: Steph
    texts:
    - language: 0
      text: Ahora haremos pasos hacia los lados.
    - language: 1
      text: Now, let make some dance to different directions
